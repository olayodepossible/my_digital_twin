# Copy to terraform.tfvars (gitignored) or rely on OPENROUTER_API_KEY in a gitignored .env file.
# Never commit real API keys. Deploy/destroy scripts map OPENROUTER_API_KEY -> TF_VAR_openrouter_api_key.

project_name             = "digital-twin"
environment              = "dev"
bedrock_model_id         = "amazon.nova-micro-v1:0"
lambda_timeout           = 60
api_throttle_burst_limit = 10
api_throttle_rate_limit  = 5
use_custom_domain        = false
root_domain              = ""
